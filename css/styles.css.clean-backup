:root{--bg:#f7f8fb;--surface:#fff;--surface2:#f2f3f8;--text:#11131a;--muted:#656b7b;--line:#e8e9ef;--primary:#5d4bff;--primary2:#2f80ff;--shadow:0 24px 80px rgba(27,31,45,.10);--soft:0 12px 35px rgba(27,31,45,.08);--radius:28px;--radius2:18px}html[data-theme=dark]{--bg:#080b11;--surface:#10141b;--surface2:#151a23;--text:#f7f8fb;--muted:#a1a8b8;--line:#252b36;--primary:#7b61ff;--primary2:#3287ff;--shadow:0 24px 80px rgba(0,0,0,.45);--soft:0 12px 35px rgba(0,0,0,.28)}*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at 62% 42%,rgba(116,91,255,.12),transparent 30%),var(--bg);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Arial,sans-serif;color:var(--text)}button,input,select{font:inherit;color:inherit}button{cursor:pointer}.app-shell{min-height:100vh;display:flex}.sidebar{width:238px;position:fixed;inset:0 auto 0 0;background:rgba(255,255,255,.62);border-right:1px solid var(--line);backdrop-filter:blur(20px);padding:34px 22px;display:flex;flex-direction:column;gap:34px}html[data-theme=dark] .sidebar{background:rgba(10,13,18,.7)}.brand{text-decoration:none;color:var(--text)}.brand-text,.mobile-brand{letter-spacing:.45em;font-size:22px;font-weight:800}.brand-text span,.mobile-brand span,.hero-copy span,.page-head span{color:var(--primary)}.side-nav{display:grid;gap:12px}.nav-item,.bottom-nav button{border:0;background:transparent;color:var(--muted);display:flex;align-items:center;gap:14px;padding:15px 18px;border-radius:16px;text-align:left}.nav-item span{font-size:20px}.nav-item.active{background:linear-gradient(135deg,rgba(93,75,255,.14),rgba(93,75,255,.05));color:var(--primary);font-weight:700}.side-card{margin-top:auto;background:var(--surface2);border:1px solid var(--line);border-radius:18px;padding:18px;display:grid;gap:5px}.side-card span,.profile-chip small{color:var(--muted);font-size:13px}.profile-chip{display:flex;align-items:center;gap:12px}.avatar{width:42px;height:42px;border-radius:50%;display:grid;place-items:center;background:linear-gradient(135deg,var(--primary),var(--primary2));color:#fff;font-weight:800}.main{margin-left:238px;width:calc(100% - 238px);padding:30px}.topbar{height:58px;display:flex;align-items:center;justify-content:flex-end}.mobile-menu,.mobile-brand{display:none}.top-actions{display:flex;align-items:center;gap:14px}.icon-btn,.ghost-btn,.square-btn{border:1px solid var(--line);background:var(--surface);border-radius:14px;padding:12px 16px;box-shadow:var(--soft)}.primary{border:0;border-radius:14px;background:linear-gradient(135deg,var(--primary),var(--primary2));color:#fff;padding:15px 25px;font-weight:700;box-shadow:0 15px 28px rgba(93,75,255,.23)}.primary.small{padding:12px 18px}.page{display:none}.page.active{display:block}.hero-grid{display:grid;grid-template-columns:1fr 1.32fr .96fr;gap:30px;align-items:stretch;min-height:calc(100vh - 110px)}.hero-copy{padding:85px 20px 20px 28px}.hero-copy h1{font-size:clamp(42px,4.2vw,70px);line-height:1.08;margin:0 0 28px;letter-spacing:-.055em}.hero-copy p{color:var(--muted);font-size:19px;line-height:1.7;margin:0 0 34px;max-width:420px}.mini-card{margin-top:80px;display:flex;align-items:center;gap:15px;background:var(--surface);border:1px solid var(--line);border-radius:20px;padding:20px;max-width:330px;box-shadow:var(--soft)}.mini-card small{display:block;color:var(--muted);margin-top:6px}.preview-stage{position:relative;display:grid;place-items:center;background:linear-gradient(145deg,rgba(255,255,255,.86),rgba(244,243,255,.72));border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}html[data-theme=dark] .preview-stage{background:linear-gradient(145deg,rgba(18,22,31,.86),rgba(18,16,36,.72))}.preview-stage:before{content:"";position:absolute;inset:15%;background:radial-gradient(circle,rgba(104,78,255,.18),transparent 58%);filter:blur(18px)}.qr-canvas{position:relative;z-index:1;background:var(--surface);border-radius:28px;padding:26px;box-shadow:var(--shadow)}.scan-chip{position:absolute;bottom:34px;z-index:2;background:rgba(255,255,255,.76);backdrop-filter:blur(15px);border:1px solid var(--line);border-radius:999px;padding:12px 18px;display:flex;align-items:center;gap:12px;color:var(--muted)}html[data-theme=dark] .scan-chip{background:rgba(11,14,20,.76)}.scan-chip input{accent-color:var(--primary)}.design-panel{background:rgba(255,255,255,.76);border:1px solid var(--line);border-radius:var(--radius);padding:22px;box-shadow:var(--shadow);backdrop-filter:blur(22px);align-self:center}html[data-theme=dark] .design-panel{background:rgba(15,19,27,.78)}.panel-tabs{display:grid;grid-template-columns:repeat(5,1fr);gap:4px;border-bottom:1px solid var(--line);margin:-6px -6px 22px}.panel-tabs button{border:0;background:transparent;color:var(--muted);padding:14px 6px;border-bottom:2px solid transparent}.panel-tabs button.active{color:var(--primary);border-color:var(--primary);font-weight:700}.editor-tab{display:none}.editor-tab.active{display:block}label{display:block;margin:18px 0 10px;color:var(--muted);font-weight:700;font-size:14px}.type-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.type-grid button,.choice-row button,.template-card,.code-row,.settings-card{border:1px solid var(--line);background:var(--surface);border-radius:16px;box-shadow:var(--soft)}.type-grid button{min-height:76px;display:grid;place-items:center;gap:5px}.type-grid button span{font-size:13px}.type-grid .selected,.choice-row .selected{border-color:var(--primary);color:var(--primary);box-shadow:0 0 0 3px rgba(93,75,255,.08)}.field-stack{display:grid;gap:12px}.input,.field-stack input,.field-stack textarea,.search-line input,.search-line select{width:100%;border:1px solid var(--line);background:var(--surface);border-radius:14px;padding:14px 16px;outline:none}.field-stack textarea{min-height:110px;resize:vertical}.choice-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}.choice-row button{padding:18px 10px}.color-row{display:flex;align-items:center;gap:14px;flex-wrap:wrap}.color-row input{width:44px;height:44px;border:0;background:transparent}.color-preset{width:44px;height:44px;border-radius:50%;border:1px solid var(--line);background:linear-gradient(135deg,var(--a),var(--b))}.upload-box{border:1px dashed var(--line);border-radius:18px;background:var(--surface2);padding:24px}.upload-box p{color:var(--muted);margin:10px 0 0}.wide{width:100%;margin-top:12px}.range-line{display:flex;align-items:center;gap:12px}.range-line button{width:42px;height:42px;border:1px solid var(--line);background:var(--surface);border-radius:12px}.range-line input{width:100%;accent-color:var(--primary)}.download-row{display:grid;grid-template-columns:1fr 84px;gap:12px;margin-top:22px}.square-btn{box-shadow:none}.page-head{padding:50px 0 25px}.page-head h2{font-size:clamp(34px,4vw,58px);line-height:1.07;letter-spacing:-.045em;margin:0 0 12px}.page-head p{color:var(--muted);font-size:18px;margin:0}.search-line{display:grid;grid-template-columns:minmax(250px,520px) 220px;gap:18px;margin-bottom:24px}.template-grid{display:grid;grid-template-columns:repeat(4,minmax(210px,1fr));gap:20px}.template-card{padding:18px;display:grid;gap:12px}.template-thumb{height:130px;border-radius:16px;background:linear-gradient(135deg,rgba(93,75,255,.12),rgba(47,128,255,.06));display:grid;place-items:center}.template-card h3{margin:0}.template-card p{margin:0;color:var(--muted)}.code-actions{display:flex;gap:14px;margin-bottom:24px}.codes-list{display:grid;gap:14px}.code-row{display:grid;grid-template-columns:78px 1fr auto auto;gap:18px;align-items:center;padding:15px}.code-row img{width:68px;height:68px;border-radius:12px;background:#fff}.code-row small{color:var(--muted)}.empty-state{background:var(--surface);border:1px solid var(--line);border-radius:24px;padding:50px;display:grid;gap:10px;max-width:650px;box-shadow:var(--soft)}.empty-state span{color:var(--muted)}.settings-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.settings-card{padding:24px}.settings-card p{color:var(--muted);line-height:1.6}.bottom-nav{display:none}.toast{position:fixed;right:26px;bottom:26px;background:var(--text);color:var(--bg);border-radius:14px;padding:14px 18px;z-index:20;box-shadow:var(--shadow)}@media(max-width:1150px){.hero-grid{grid-template-columns:1fr}.hero-copy{padding-top:30px}.design-panel{align-self:stretch}.template-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:760px){body{background:var(--bg)}.app-shell{display:block}.sidebar{display:none}.main{margin-left:0;width:100%;padding:20px 18px 110px}.topbar{height:auto;justify-content:space-between;margin-bottom:18px}.mobile-menu,.mobile-brand{display:block}.mobile-menu{border:0;background:var(--surface);border-radius:14px;padding:12px 14px;box-shadow:var(--soft)}.top-actions .ghost-btn,.top-actions .primary{display:none}.hero-grid{gap:18px;min-height:auto}.hero-copy{padding:10px 6px}.hero-copy h1{font-size:46px}.hero-copy p{font-size:17px}.mini-card{display:none}.preview-stage{min-height:360px;border-radius:30px}.qr-canvas{transform:scale(.86);padding:18px}.design-panel{padding:18px;border-radius:24px}.type-grid{grid-template-columns:repeat(3,1fr)}.choice-row{grid-template-columns:repeat(3,1fr)}.panel-tabs{overflow:auto;grid-template-columns:repeat(5,86px)}.search-line{grid-template-columns:1fr}.template-grid{grid-template-columns:1fr}.settings-grid{grid-template-columns:1fr}.code-actions{flex-direction:column}.code-row{grid-template-columns:72px 1fr;}.code-row button,.code-row .meta-extra{grid-column:2}.bottom-nav{position:fixed;left:18px;right:18px;bottom:18px;z-index:12;background:rgba(255,255,255,.82);border:1px solid var(--line);backdrop-filter:blur(20px);border-radius:24px;box-shadow:var(--shadow);display:grid;grid-template-columns:repeat(4,1fr);padding:10px}html[data-theme=dark] .bottom-nav{background:rgba(15,19,27,.82)}.bottom-nav button{justify-content:center;display:grid;gap:5px;padding:12px 6px;border-radius:18px}.bottom-nav button.active{background:rgba(93,75,255,.12);color:var(--primary)}.bottom-nav span{font-size:12px}.page-head{padding-top:20px}.page-head h2{font-size:42px}}
